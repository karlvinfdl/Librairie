{% extends 'base.html.twig' %}

{% block title %}Librairie — Livres{% endblock %}

{% block body %}

  <div class="row justify-content-center">
    <div class="col-lg-10">

      <div class="card shadow-sm mb-3">
        <div class="card-body">
          <h1 class="h4 mb-1">Librairie</h1>
          <p class="text-muted mb-0">Ajouter / Supprimer un livre</p>
        </div>
      </div>

      <div class="card shadow-sm mb-3">
        <div class="card-body">
          <h2 class="h5 mb-3">➕ Ajouter un livre</h2>

          {# ✅ Seulement pour les users connectés #}
          {% if app.user %}
            <form method="post" action="{{ path('app_home') }}" class="row g-2 align-items-end">
              <input type="hidden" name="action" value="add">

              <div class="col-md-7">
                <label class="form-label">Titre</label>
                <input class="form-control" name="titre" placeholder="Ex: Dune" required>
              </div>

              <div class="col-md-3">
                <label class="form-label">Prix (€)</label>
                <input class="form-control" name="prix" placeholder="Ex: 19.99" required>
              </div>

              <div class="col-md-2 d-grid">
                <button class="btn btn-dark" type="submit">Ajouter</button>
              </div>
            </form>
          {% else %}
            <div class="alert alert-warning mb-0">
              Tu dois être connecté pour ajouter un livre.
              <a class="alert-link" href="{{ path('app_login') }}">Se connecter</a>
              ou
              <a class="alert-link" href="{{ path('app_register') }}">s’inscrire</a>.
            </div>
          {% endif %}
        </div>
      </div>

      <div class="card shadow-sm">
        <div class="card-body">
          <h2 class="h5 mb-3">📚 Livres</h2>

          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th style="width: 80px;">ID</th>
                  <th>Titre</th>
                  <th style="width: 130px;">Prix</th>
                  <th style="width: 180px;">Action</th>
                </tr>
              </thead>

              <tbody>
              {% for p in produits %}
                <tr>
                  <td>{{ p.id }}</td>
                  <td>{{ p.titre }}</td>
                  <td>{{ p.prix }} €</td>
                  <td>
                    {# ✅ Bouton supprimer visible uniquement pour admin #}
                    {% if is_granted('ROLE_ADMIN') %}
                      <form method="post"
                            action="{{ path('app_produit_delete', {id: p.id}) }}"
                            onsubmit="return confirm('Supprimer ce livre ?');"
                            class="m-0">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_produit_' ~ p.id) }}">
                        <button class="btn btn-danger btn-sm" type="submit">Supprimer</button>
                      </form>
                    {% else %}
                      <span class="text-muted small">Admin uniquement</span>
                    {% endif %}
                  </td>
                </tr>
              {% else %}
                <tr>
                  <td colspan="4" class="text-muted">Aucun livre.</td>
                </tr>
              {% endfor %}
              </tbody>
            </table>
          </div>

        </div>
      </div>

    </div>
  </div>

{% endblock %}