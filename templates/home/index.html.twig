{% extends 'base.html.twig' %}

{% block title %}Librairie — Livres{% endblock %}

{% block body %}
<div class="page-books">
  <div class="row justify-content-center">
    <div class="col-lg-10">

      <header class="card shadow-sm mb-3 page-header">
        <div class="card-body">
          <h1 class="h4 mb-1">Librairie</h1>
          <p class="text-muted mb-0">Ajouter / Modifier / Supprimer un livre</p>
        </div>
      </header>

      {# Flash messages #}
      {% for msg in app.flashes('success') %}
        <div class="alert alert-success">{{ msg }}</div>
      {% endfor %}
      {% for msg in app.flashes('error') %}
        <div class="alert alert-danger">{{ msg }}</div>
      {% endfor %}

      <section class="card shadow-sm mb-3">
        <div class="card-body">
          <h2 class="h5 mb-3">➕ Ajouter un livre</h2>

          {% if app.user %}
            <form method="post"
                  action="{{ path('app_home') }}"
                  enctype="multipart/form-data"
                  class="row g-2 align-items-end js-add-book-form">
              <input type="hidden" name="action" value="add">

              <div class="col-md-5">
                <label class="form-label" for="titre">Titre</label>
                <input id="titre" class="form-control" name="titre" placeholder="Ex: Dune" required>
              </div>

              <div class="col-md-2">
                <label class="form-label" for="prix">Prix (€)</label>
                <input id="prix" class="form-control" name="prix" placeholder="Ex: 19.99" required inputmode="decimal">
              </div>

              <div class="col-md-3">
                <label class="form-label" for="image">Image</label>
                <input id="image" type="file" class="form-control" name="image" accept="image/*">
              </div>

              <div class="col-md-2 d-grid">
                <button class="btn btn-dark" type="submit">Ajouter</button>
              </div>

              <input type="hidden" name="_token" value="{{ csrf_token('add_produit') }}">
            </form>
          {% else %}
            <div class="alert alert-warning mb-0">
              Tu dois être connecté pour ajouter un livre.
              <a class="alert-link" href="{{ path('app_login') }}">Se connecter</a>
              ou
              <a class="alert-link" href="{{ path('app_register') }}">s’inscrire</a>.
            </div>
          {% endif %}
        </div>
      </section>

      <section class="card shadow-sm">
        <div class="card-body">
          <div class="d-flex align-items-center justify-content-between gap-2 mb-3">
            <h2 class="h5 mb-0">📚 Livres</h2>
            <input class="form-control form-control-sm page-books__search js-book-search"
                   style="max-width: 260px;"
                   placeholder="Rechercher un titre...">
          </div>

          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 js-books-table">
              <thead class="table-light">
                <tr>
                  <th style="width: 90px;">Image</th>
                  <th>Titre</th>
                  <th style="width: 130px;">Prix</th>
                  <th style="width: 260px;">Action</th>
                </tr>
              </thead>

              <tbody>
              {% for p in produits %}
                <tr class="js-book-row">
                  <td>
                    {% if p.imageMime %}
                      <img
                        src="{{ path('app_produit_image', {id: p.id}) }}"
                        alt="Couverture {{ p.titre }}"
                        class="book-cover"
                      >
                    {% else %}
                      <div class="book-cover book-cover--empty">—</div>
                    {% endif %}
                  </td>

                  <td class="js-book-title">{{ p.titre }}</td>
                  <td>{{ p.prix }} €</td>

                  <td>
                    <div class="d-flex gap-2">
                      {# USER peut modifier #}
                      {% if is_granted('ROLE_USER') %}
                        <a class="btn btn-outline-primary btn-sm"
                           href="{{ path('app_produit_edit', {id: p.id}) }}">
                          Modifier
                        </a>
                      {% endif %}

                      {# ADMIN peut supprimer #}
                      {% if is_granted('ROLE_ADMIN') %}
                        <form method="post"
                              action="{{ path('app_produit_delete', {id: p.id}) }}"
                              class="m-0 js-delete-book-form"
                              data-confirm="Supprimer ce livre ?">
                          <input type="hidden" name="_token" value="{{ csrf_token('delete_produit_' ~ p.id) }}">
                          <button class="btn btn-danger btn-sm" type="submit">Supprimer</button>
                        </form>
                      {% endif %}
                    </div>
                  </td>
                </tr>
              {% else %}
                <tr>
                  <td colspan="4" class="text-muted">Aucun livre.</td>
                </tr>
              {% endfor %}
              </tbody>
            </table>
          </div>

        </div>
      </section>

    </div>
  </div>
</div>
{% endblock %}